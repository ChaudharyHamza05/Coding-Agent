# Google AI Studio se free Gemini API key lein: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_free_gemini_api_key_here

# Optional: chat model (default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional: embedding model, RAG/semantic search ke liye (default text-embedding-004)
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Optional: ChromaDB (persistent memory) is folder me store hoga
CHROMA_DIR=data/chroma

# Optional: har session ki files is folder me store hongi
WORKSPACE_DIR=workspace
